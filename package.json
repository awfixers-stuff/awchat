{
  "name": "awchat",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "description": "Encrypted ephemeral chat for Android",
  "author": {
    "name": "awfixer",
    "email": "awfixer@hey.com",
    "url": "https://awfixer.me"
  },
  "scripts": {
    "lint": "oxlint --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "typecheck": "tsgo --noEmit",
    "changelog": "bun scripts/changelog.ts",
    "agents:handoff": "bun scripts/update-agents-md.ts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@oxfmt/binding-linux-x64-gnu": "0.53.0",
    "@oxlint/binding-linux-x64-gnu": "1.68.0",
    "@types/bun": "1.3.14",
    "@typescript/native-preview": "7.0.0-dev.20260605.1",
    "@typescript/native-preview-linux-x64": "7.0.0-dev.20260605.1",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "lefthook": "2.1.9",
    "lefthook-linux-x64": "2.1.9",
    "vitest": "4.1.8",
    "typescript": "6.0.3"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "error"
    }
  },
  "engines": {
    "bun": "1.3.14"
  },
  "packageManager": "bun@1.3.14"
}
