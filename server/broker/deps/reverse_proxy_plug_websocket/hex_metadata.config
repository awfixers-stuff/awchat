{<<"app">>,<<"reverse_proxy_plug_websocket">>}.
{<<"build_tools">>,[<<"mix">>]}.
{<<"description">>,
 <<"Support reverse proxying of websocket connections natively in Elixir">>}.
{<<"elixir">>,<<"~> 1.13">>}.
{<<"files">>,
 [<<"lib">>,<<"lib/reverse_proxy_plug_websocket.ex">>,
  <<"lib/reverse_proxy_plug_websocket">>,
  <<"lib/reverse_proxy_plug_websocket/proxy_process.ex">>,
  <<"lib/reverse_proxy_plug_websocket/config.ex">>,
  <<"lib/reverse_proxy_plug_websocket/websocket_client.ex">>,
  <<"lib/reverse_proxy_plug_websocket/websocket_handler.ex">>,
  <<"lib/reverse_proxy_plug_websocket/adapters">>,
  <<"lib/reverse_proxy_plug_websocket/adapters/websockex_client.ex">>,
  <<"lib/reverse_proxy_plug_websocket/adapters/websockex.ex">>,
  <<"lib/reverse_proxy_plug_websocket/adapters/gun.ex">>,<<".formatter.exs">>,
  <<"mix.exs">>,<<"README.md">>,<<"LICENSE">>]}.
{<<"licenses">>,[<<"Apache-2.0">>]}.
{<<"links">>,
 [{<<"GitHub">>,
   <<"https://github.com/mwhitworth/reverse_proxy_plug_websocket">>}]}.
{<<"name">>,<<"reverse_proxy_plug_websocket">>}.
{<<"requirements">>,
 [[{<<"app">>,<<"plug">>},
   {<<"name">>,<<"plug">>},
   {<<"optional">>,false},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 1.14">>}],
  [{<<"app">>,<<"gun">>},
   {<<"name">>,<<"gun">>},
   {<<"optional">>,true},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 2.0">>}],
  [{<<"app">>,<<"websockex">>},
   {<<"name">>,<<"websockex">>},
   {<<"optional">>,true},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 0.4.3">>}],
  [{<<"app">>,<<"websock_adapter">>},
   {<<"name">>,<<"websock_adapter">>},
   {<<"optional">>,false},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 0.5">>}],
  [{<<"app">>,<<"websock">>},
   {<<"name">>,<<"websock">>},
   {<<"optional">>,false},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 0.5">>}]]}.
{<<"version">>,<<"0.2.0">>}.
