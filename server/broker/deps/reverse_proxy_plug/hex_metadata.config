{<<"app">>,<<"reverse_proxy_plug">>}.
{<<"build_tools">>,[<<"mix">>]}.
{<<"description">>,
 <<"An Elixir reverse proxy Plug with HTTP/2, chunked transfer and path proxying support.">>}.
{<<"elixir">>,<<"~> 1.13">>}.
{<<"files">>,
 [<<"lib">>,<<"lib/reverse_proxy_plug.ex">>,<<"lib/reverse_proxy_plug">>,
  <<"lib/reverse_proxy_plug/http_client">>,
  <<"lib/reverse_proxy_plug/http_client/response.ex">>,
  <<"lib/reverse_proxy_plug/http_client/maybe_redirect.ex">>,
  <<"lib/reverse_proxy_plug/http_client/request.ex">>,
  <<"lib/reverse_proxy_plug/http_client/error.ex">>,
  <<"lib/reverse_proxy_plug/http_client/adapters">>,
  <<"lib/reverse_proxy_plug/http_client/adapters/tesla.ex">>,
  <<"lib/reverse_proxy_plug/http_client/adapters/finch.ex">>,
  <<"lib/reverse_proxy_plug/http_client/adapters/httpoison.ex">>,
  <<"lib/reverse_proxy_plug/http_client/adapters/req.ex">>,
  <<"lib/reverse_proxy_plug/http_client.ex">>,<<".formatter.exs">>,
  <<"mix.exs">>,<<"README.md">>,<<"LICENSE.md">>,<<"CHANGELOG.md">>]}.
{<<"licenses">>,[<<"MIT">>]}.
{<<"links">>,
 [{<<"GitHub">>,<<"https://github.com/tallarium/reverse_proxy_plug">>}]}.
{<<"name">>,<<"reverse_proxy_plug">>}.
{<<"requirements">>,
 [[{<<"app">>,<<"req">>},
   {<<"name">>,<<"req">>},
   {<<"optional">>,true},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 0.3.0 or ~> 0.4.0 or ~> 0.5.0">>}],
  [{<<"app">>,<<"finch">>},
   {<<"name">>,<<"finch">>},
   {<<"optional">>,true},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 0.18">>}],
  [{<<"app">>,<<"plug">>},
   {<<"name">>,<<"plug">>},
   {<<"optional">>,false},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 1.6">>}],
  [{<<"app">>,<<"httpoison">>},
   {<<"name">>,<<"httpoison">>},
   {<<"optional">>,true},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 1.4 or ~> 2.0">>}],
  [{<<"app">>,<<"tesla">>},
   {<<"name">>,<<"tesla">>},
   {<<"optional">>,true},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 1.4">>}]]}.
{<<"version">>,<<"3.0.4">>}.
