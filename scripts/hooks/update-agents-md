#!/usr/bin/env sh
set -e

root="$(git rev-parse --show-toplevel)"
cd "$root"

export AWCHAT_REPO_ROOT="$root"
. "$root/scripts/hooks/lib/resolve-bun.sh"

if ! awchat_resolve_bun; then
  echo "update-agents-md: bun not found — skipped" >&2
  exit 0
fi

exec "$AWCHAT_BUN" "$root/scripts/update-agents-md.ts"