#!/usr/bin/env sh
set -e

root="$(git rev-parse --show-toplevel)"
cd "$root"

export AWCHAT_REPO_ROOT="$root"
. "$root/scripts/hooks/lib/resolve-bun.sh"

if ! awchat_resolve_bun; then
  echo "pre-commit changelog: bun not found in PATH" >&2
  exit 1
fi

exec "$AWCHAT_BUN" "$root/scripts/changelog.ts"