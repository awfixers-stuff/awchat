#!/usr/bin/env sh
set -e

root="$(git rev-parse --show-toplevel)"
cd "$root"

export AWCHAT_REPO_ROOT="$root"
. "$root/scripts/hooks/lib/resolve-bun.sh"

export AWCHAT_HOOK_PHASE=uncommitted
export AWCHAT_CODERABBIT_QUEUE=1

if ! awchat_resolve_bun; then
  echo "agent-turn-coderabbit: bun not found (install bun or set AWCHAT_BUN)" >&2
  exit 1
fi

"$AWCHAT_BUN" "$root/scripts/hooks/coderabbit-run.ts"
"$AWCHAT_BUN" "$root/scripts/hooks/emit-coderabbit-prompt.ts"