#!/usr/bin/env sh
set -e

root="$(git rev-parse --show-toplevel)"
cd "$root"

export AWCHAT_REPO_ROOT="$root"
. "$root/scripts/hooks/lib/resolve-bun.sh"

export AWCHAT_HOOK_PHASE=pre-push
export AWCHAT_CODERABBIT_QUEUE=1
export AWCHAT_CODERABBIT_FAIL_CRITICAL=1

if ! awchat_resolve_bun; then
  echo "pre-push coderabbit: bun not found — skipped" >&2
  exit 0
fi

"$AWCHAT_BUN" "$root/scripts/hooks/coderabbit-run.ts"
exit $?