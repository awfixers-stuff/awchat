{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh scripts/hooks/agent-turn-coderabbit",
            "timeout": 120,
            "env": {
              "PATH": "${HOME}/.bun/bin:${HOME}/.local/bin:/usr/local/bin:/nix/var/nix/profiles/default/bin:${PATH}"
            }
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh scripts/hooks/agent-turn-coderabbit",
            "timeout": 120,
            "env": {
              "PATH": "${HOME}/.bun/bin:${HOME}/.local/bin:/usr/local/bin:/nix/var/nix/profiles/default/bin:${PATH}"
            }
          }
        ]
      }
    ]
  }
}
